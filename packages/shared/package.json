{
  "name": "@opencode-janitor/shared",
  "version": "0.1.0",
  "description": "Shared domain logic — schemas, types, config, git utilities",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "generate:agents": "bun run scripts/generate-agent-manifest.ts",
    "check:agents-manifest": "bun run scripts/generate-agent-manifest.ts --check",
    "build": "bun run check:agents-manifest && tsc --noEmit",
    "typecheck": "bun run check:agents-manifest && tsc --noEmit",
    "test": "bun run check:agents-manifest && bun test"
  },
  "dependencies": {
    "zod": "^4.1.8"
  }
}
