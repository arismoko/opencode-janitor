{
  "name": "@opencode-janitor/plugin",
  "version": "0.1.0",
  "description": "Automatic structural code health reviews for OpenCode",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "code-review",
    "code-health",
    "janitor",
    "dead-code",
    "dry",
    "yagni"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "inspect:review-sessions": "bun script/inspect-review-sessions.ts",
    "dev": "bun run build && opencode"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.1.19",
    "@opencode-ai/sdk": "^1.1.19",
    "zod": "^4.1.8"
  }
}
